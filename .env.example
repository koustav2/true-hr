# Copy this file to ".env" (next to docker-compose.yml) and fill in your SMTP details.
# docker compose reads these automatically. Restart with:  docker compose up -d

# --- Security (recommended to set your own) ---
JWT_SECRET=change-me-to-a-long-random-string
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Email (SMTP) ---
# The "From" shown on emails. For Gmail this should be your Gmail address.
MAIL_FROM=TRUE HR <youraddress@gmail.com>

# Gmail example (recommended for testing):
#   1) Enable 2-Step Verification on the Google account
#   2) Create an "App password" (Google Account → Security → App passwords)
#   3) Use that 16-char app password below (NOT your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password

# Other providers (examples):
#   Outlook/365 : SMTP_HOST=smtp.office365.com  SMTP_PORT=587
#   Mailgun     : SMTP_HOST=smtp.mailgun.org    SMTP_PORT=587
#   Brevo       : SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587
#   Mailtrap*   : SMTP_HOST=sandbox.smtp.mailtrap.io SMTP_PORT=587   (*captures mail, doesn't deliver — great for testing)

# Leave SENDGRID_API_KEY empty to force SMTP.
SENDGRID_API_KEY=
