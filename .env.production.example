# Copy to ".env.production" on the VPS and fill in real values. NEVER commit the real file.
#   cp .env.production.example .env.production && nano .env.production

# --- Database (runs in the db container) ---
POSTGRES_USER=truehr
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=truehr

# --- Security (generate fresh, unique values) ---
# JWT_SECRET:        node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# PII_ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  (must be 64 hex chars)
JWT_SECRET=CHANGE_ME_long_random_string
PII_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# --- Email (SMTP) ---
MAIL_FROM=TRUE HR <no-reply@truehr.co.in>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
SENDGRID_API_KEY=
