{
  "name": "truehr-backend",
  "version": "1.0.0",
  "description": "TRUE HR HRMS backend (Express + PostgreSQL)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "start:docker": "node src/db/migrate.js && node src/db/seed.js && node src/server.js"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "pdfkit": "^0.15.2",
    "pg": "^8.12.0"
  }
}
